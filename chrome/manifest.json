{
  "manifest_version": 3,
  "name": "AI Web Summarizer",
  "version": "1.1.0",
  "description": "Summarize any webpage using ChatGPT or OpenRouter AI",
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Web Summarizer",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "commands": {
    "summarize": {
      "suggested_key": {
        "default": "Ctrl+Alt+S"
      },
      "description": "Summarize this page"
    }
  },
  "background": {
    "service_worker": "background.js"
  }

}

